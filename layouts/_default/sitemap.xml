{{- $pages := .Site.Pages -}}
<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range $pages }}
  {{- if .IsPage }}
  {{- $priority := "0.5" }}
  {{- if eq .Kind "home" }}{{- $priority = "1.0" }}{{- end }}
  {{- if eq .Section "stages" }}{{- $priority = "0.9" }}{{- end }}
  {{- if or (eq .RelPermalink "/ohmoveagain/calculator/") (eq .RelPermalink "/ohmoveagain/contribute/") }}{{- $priority = "0.7" }}{{- end }}
  {{- if .Params.noindex }}{{- continue }}{{- end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02" }}</lastmod>
    {{- end }}
    <changefreq>weekly</changefreq>
    <priority>{{ $priority }}</priority>
  </url>
  {{- end }}
  {{- end }}
</urlset>
